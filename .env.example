# Khớp với docker-compose.yml (service postgres)
DATABASE_URL=postgresql://cms:cms_secret@localhost:5432/cms_cua_iet

# Seed admin mặc định: npm run db:seed → admin@gmail.com / 12345678 (đổi sau khi deploy)
# Ghi đè tùy chọn:
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=Quản trị viên
